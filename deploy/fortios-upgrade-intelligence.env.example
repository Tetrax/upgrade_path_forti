# Exemple de configuration SMTP pour les notifications email de FortiOS Upgrade Intelligence.
#
# Copier ce fichier en /etc/fortios-upgrade-intelligence.env (hors du dépôt Git, permissions
# restreintes, ex: chmod 600 root:root ou tetrax:tetrax selon l'utilisateur du service), puis
# renseigner de vraies valeurs. Ne JAMAIS committer de vrais identifiants dans ce dépôt.
#
# Absence totale de ce fichier, ou FORTIOS_EMAIL_ENABLED=false : fonctionnement normal, aucun
# email envoyé, aucune erreur.

# Interrupteur général — false par défaut.
FORTIOS_EMAIL_ENABLED=false

# Serveur SMTP.
FORTIOS_SMTP_HOST=
FORTIOS_SMTP_PORT=587
FORTIOS_SMTP_USERNAME=
FORTIOS_SMTP_PASSWORD=
FORTIOS_SMTP_STARTTLS=true
FORTIOS_SMTP_TIMEOUT=10

# Expéditeur et destinataires (plusieurs destinataires séparés par des virgules).
FORTIOS_SMTP_FROM=
FORTIOS_SMTP_TO=

# Utilisé dans le corps des emails (lien vers l'application).
FORTIOS_APP_URL=https://valdev.me:3001/app/
